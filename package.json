{
  "name": "orchestra",
  "version": "0.0.0",
  "description": "Local coding-agent orchestrator for Bun, tmux, git worktrees, and OpenTUI.",
  "type": "module",
  "private": true,
  "bin": {
    "orchestra": "./dist/orchestra.js"
  },
  "scripts": {
    "dev": "bun run src/cli/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli/main.ts --target=bun --outdir=dist --entry-naming=orchestra.js --external @opentui/core --external @opentui/react --external react"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "bun-types": "^1.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "^0.2.15",
    "@opentui/react": "^0.2.15",
    "react": "^19.2.6"
  }
}
